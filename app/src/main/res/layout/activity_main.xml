<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <!-- ══════════ 顶部 Header ══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_gradient"
        android:orientation="vertical"
        android:paddingTop="52dp"
        android:paddingBottom="28dp"
        android:paddingHorizontal="24dp">

        <!-- APP 标题行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="智能录音机"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>

            <TextView
                android:id="@+id/tvRecordingCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/status_capsule"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="0 条录音"
                android:textColor="#FFFFFF"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- 计时器大字 -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="64sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="-0.03"
            android:layout_marginBottom="14dp"/>

        <!-- 波形 -->
        <com.voicerecorder.app.WaveformView
            android:id="@+id/waveformView"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="14dp"/>

        <!-- 状态文字 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="轻触下方按钮开始录音"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"/>

    </LinearLayout>

    <!-- ══════════ 录音按钮区 ══════════ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:background="@color/bg_main">

        <!-- 外圈光晕 -->
        <View
            android:id="@+id/ringOuter"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_centerInParent="true"
            android:background="@drawable/record_btn_ring_outer"/>

        <!-- 中圈 -->
        <View
            android:id="@+id/ringMid"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_centerInParent="true"
            android:background="@drawable/record_btn_ring_mid"/>

        <!-- 主按钮 -->
        <LinearLayout
            android:id="@+id/fabRecord"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_centerInParent="true"
            android:background="@drawable/record_btn_main"
            android:gravity="center"
            android:elevation="8dp">
            <ImageView
                android:id="@+id/ivRecordIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_mic"
                app:tint="@color/white"/>
        </LinearLayout>

    </RelativeLayout>

    <!-- ══════════ 录音列表区 ══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- 列表标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp">

            <View
                android:layout_width="4dp"
                android:layout_height="18dp"
                android:background="@drawable/card_accent_bar"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="我的录音"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- 空状态 -->
        <LinearLayout
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="40dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="暂无录音"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="轻触上方按钮开始录制"
                android:textColor="@color/text_hint"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- 列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecordings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:paddingBottom="20dp"
            android:clipToPadding="false"/>

    </LinearLayout>

</LinearLayout>
